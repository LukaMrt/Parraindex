{
    "name": "lukamrt/parraindex",
    "description": "School project that stores the list of godfathers and godchildren at the IUT Lyon 1",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.3",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^v2.10",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^v4.0",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/security-csrf": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/reset-password-bundle": "^1.24",
        "symfonycasts/sass-bundle": "^0.9",
        "symfonycasts/verify-email-bundle": "^1.18",
        "twig/extra-bundle": "^v3.22",
        "twig/twig": "^v3.22"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "fixtures": [
            "php bin/console doctrine:fixtures:load --no-interaction"
        ],
        "migration-diff": [
            "php bin/console make:migration"
        ],
        "migration": [
            "php bin/console doctrine:migrations:migrate --no-interaction"
        ],
        "test": [
            "php bin/phpunit"
        ],
        "rector": [
            "php vendor/bin/rector process"
        ],
        "rector-dry": [
            "php vendor/bin/rector process --dry-run"
        ],
        "phpstan": [
            "php vendor/bin/phpstan --memory-limit=1G"
        ],
        "phpcs": [
            "php vendor/bin/phpcs --cache=var/cache/phpcs"
        ],
        "phpcs-fix": [
            "php vendor/bin/phpcbf"
        ],
        "server-start": [
            "symfony server:start -d"
        ],
        "server-stop": [
            "symfony server:stop"
        ],
        "server-restart": [
            "@server-stop",
            "@server-start"
        ],
        "server-log": [
            "symfony server:log"
        ],
        "clear_cache": [
            "php bin/console cache:clear"
        ],
        "build-scss": [
            "php bin/console sass:build",
            "php bin/console asset-map:compile"
        ],
        "docker": "docker buildx build --platform linux/arm64 -t lukamrt/parraindex --push ."
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.4",
        "doctrine/doctrine-fixtures-bundle": "4.3.*",
        "infection/infection": "^0.32",
        "phpstan/phpstan": "2.1.*",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "2.3.*",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.65",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*"
    }
}
